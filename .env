# TrialNav — Environment Variables
# Copy this to .env and fill in your values.

# ── Google AI Studio (FREE) ───────────────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
# Free quota: 1,500 requests/day on Gemini 2.0 Flash
GEMINI_API_KEY=AIzaSyB3L2vevvsQDLX5olbP67_dMWeer8Pu8AA

# Gemini model — gemini-2.0-flash is the free tier model
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (CPU fallback — no API key needed) ─────────────────────────────────
# Set USE_OLLAMA=true to skip Gemini and use a local Ollama model instead.
# Install Ollama: https://ollama.ai
# Pull model: ollama pull gemma2:2b
USE_OLLAMA=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b

# ── App Settings ──────────────────────────────────────────────────────────────
API_PORT=8001
UI_PORT=7860
LOG_LEVEL=INFO
