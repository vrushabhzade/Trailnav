{
    "version": 2,
    "buildCommand": "cd web && npm install && npm run build",
    "outputDirectory": "web/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/main.py"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}