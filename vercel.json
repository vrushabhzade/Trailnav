{
    "version": 2,
    "builds": [
        {
            "src": "api/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "web/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/main.py"
        },
        {
            "src": "/docs",
            "dest": "api/main.py"
        },
        {
            "src": "/openapi.json",
            "dest": "api/main.py"
        },
        {
            "src": "/health",
            "dest": "api/main.py"
        },
        {
            "src": "/(.*)",
            "dest": "web/dist/$1"
        }
    ]
}